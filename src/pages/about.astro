---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于 - Me Blog">
  <ParticleBackground />
  <Header />
  <main>
    <section class="about-page">
      <div class="about-card glass">
        <div class="avatar-container">
          <img src="/me_blog/images/avatar.jpg" alt="avatar" class="avatar-img" />
        </div>
        <h1 class="about-name">lc0626</h1>
        <p class="about-role">嵌入式开发者 · IoT探索者</p>
        <div class="about-bio">
          <p>专注于4G模组开发（L610 / ML307A / ML307N / A7670G）</p>
          <p>相信技术可以让生活更有趣</p>
        </div>
        <div class="about-tags">
          <span class="tag">嵌入式C</span>
          <span class="tag">4G/IoT</span>
          <span class="tag">ESP32</span>
          <span class="tag">BLE</span>
          <span class="tag">自动化</span>
                  </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about-page {
    position: relative;
    z-index: 1;
    padding: 8rem 2rem 2rem;
    display: flex;
    justify-content: center;
  }

  .about-card {
    max-width: 500px;
    width: 100%;
    padding: 3rem 2rem;
    border-radius: 20px;
    text-align: center;
  }

  .avatar-container {
    margin-bottom: 1.5rem;
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--sakura-pink), var(--lavender));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    margin: 0 auto;
    box-shadow: 0 0 30px rgba(255, 183, 213, 0.3);
    animation: float 3s ease-in-out infinite;
    overflow: hidden;
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .about-name {
    font-size: 1.8rem;
    margin-bottom: 0.3rem;
    background: linear-gradient(135deg, var(--sakura-pink), var(--sky-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-family: 'Ma Shan Zheng', cursive;
  }

  .about-role {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .about-bio p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .tag {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    background: rgba(255, 183, 213, 0.1);
    color: var(--sakura-pink);
    border: 1px solid rgba(255, 183, 213, 0.2);
    transition: all 0.3s ease;
  }

  .tag:hover {
    background: rgba(255, 183, 213, 0.2);
    transform: translateY(-2px);
  }
</style>
