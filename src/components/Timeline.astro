---
const modules = import.meta.glob('../content/versions/**/*.md', { eager: true });

interface CommitGroup {
  date: string;
  messages: string[];
}

interface VersionNode {
  version: string;
  date: string;
  dateNum: number;
  title: string;
  icon: string;
  color: string;
  category: string;
  categoryLabel: string;
  commits: CommitGroup[];
}

const categoryMap: Record<string, string> = {
  z_general: 'Z系列通用固件',
  z_geely: 'Z系列吉利固件',
  z_xuyu808: 'Z系列旭宇808固件',
  gd_general: 'GD通用',
  gd_geely: 'GD吉利固件',
  gd_d92hat: 'GD D92H-AT',
};

const versions: VersionNode[] = [];

for (const [path, mod] of Object.entries(modules)) {
  const parts = path.split('/');
  const folder = parts[parts.length - 2];
  const filename = parts[parts.length - 1].replace('.md', '');

  const dateMatch = filename.match(/^cy(\d{2})(\d{2})(\d{2})(\d{2})(\d{2})$/);
  let dateStr = '';
  let dateNum = 0;
  if (dateMatch) {
    const [, yy, mm, dd, hh, mi] = dateMatch;
    dateStr = `20${yy}-${mm}-${dd}`;
    dateNum = new Date(`20${yy}-${mm}-${dd}T${hh}:${mi}:00`).getTime();
  }

  const fm = (mod as any).frontmatter || {};
  
  versions.push({
    version: filename,
    date: dateStr,
    dateNum,
    title: fm.title || filename,
    icon: fm.icon || '✿',
    color: fm.color || 'pink',
    category: folder,
    categoryLabel: categoryMap[folder] || folder,
    commits: fm.commits || [],
  });
}

versions.sort((a, b) => b.dateNum - a.dateNum);

const categories = Object.keys(categoryMap).filter(cat => 
  versions.some(v => v.category === cat)
);
---

<section class="timeline-section" id="timeline">
  <div class="category-tabs">
    {categories.map(cat => (
      <button class={`tab-btn ${cat === categories[0] ? 'active' : ''}`} data-category={cat}>
          <span class="tab-icon">
            {cat === 'z_general' ? '📦' : cat === 'z_geely' ? '🚚' : cat === 'z_xuyu808' ? '🏭' : cat === 'gd_general' ? '⚡' : cat === 'gd_geely' ? '⚡' : '🔧'}
          </span>
        {categoryMap[cat]}
      </button>
    ))}
  </div>

  <h2 class="section-title">
    <span class="title-decoration">✧</span>
    版本树
    <span class="title-decoration">✧</span>
  </h2>

  <div class="timeline">
    {versions.map((v, i) => (
      <div class={`timeline-item ${i % 2 === 0 ? 'left' : 'right'} color-${v.color} ${v.category !== categories[0] ? 'tab-hidden' : ''}`}
           data-category={v.category}>
        <div class="timeline-connector">
          <div class="timeline-dot"></div>
        </div>
        <div class="timeline-card glass">
          <div class="card-header">
            <span class="category-tag">{v.categoryLabel}</span>
            <span class="card-date">{v.date}</span>
          </div>
          <h3 class="card-title">
            <span class="card-icon">{v.icon}</span>
            {v.title}
          </h3>
          {v.commits.length > 0 && (
            <div class="card-commits" style="display: none;">
              {v.commits.map((cg) => (
                <div class="commit-group">
                  <div class="commit-date">提交日期: {cg.date}</div>
                  <ol class="commit-list">
                    {cg.messages.map((msg) => (
                      <li>{msg}</li>
                    ))}
                  </ol>
                </div>
              ))}
            </div>
          )}
          {v.commits.length > 0 && (
            <button class="expand-btn">
              <span class="expand-text">展开详情</span>
              <span class="expand-icon">▼</span>
            </button>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.expand-btn');
    if (!btn) return;
    
    const card = btn.closest('.timeline-card')!;
    const commits = card.querySelector('.card-commits') as HTMLElement;
    const text = btn.querySelector('.expand-text')!;
    const icon = btn.querySelector('.expand-icon') as HTMLElement;

    if (!commits || commits.style.display === 'none' || !commits.style.display) {
      if (!commits) return;
      commits.style.display = 'block';
      requestAnimationFrame(() => {
        commits.style.maxHeight = commits.scrollHeight + 'px';
        commits.style.opacity = '1';
      });
      text.textContent = '收起详情';
      icon.style.transform = 'rotate(180deg)';
      card.classList.add('expanded');
    } else {
      commits.style.maxHeight = '0';
      commits.style.opacity = '0';
      setTimeout(() => { commits.style.display = 'none'; }, 300);
      text.textContent = '展开详情';
      icon.style.transform = 'rotate(0deg)';
      card.classList.remove('expanded');
    }
  });

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.getAttribute('data-category');
        document.querySelectorAll('.timeline-item').forEach(item => {
          const match = item.getAttribute('data-category') === cat;
          item.classList.toggle('tab-hidden', !match);
          if (match) item.classList.add('visible');
        });
      });
    });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.timeline-item').forEach(el => observer.observe(el));
</script>

<style>
  .timeline-section {
    position: relative;
    z-index: 1;
    padding: 4rem 2rem 6rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .category-tabs {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    padding: 0 1rem;
  }

  .tab-btn {
    background: rgba(21, 21, 48, 0.7);
    border: 1px solid rgba(255, 183, 213, 0.15);
    border-radius: 25px;
    padding: 0.5rem 1.2rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: inherit;
    backdrop-filter: blur(8px);
  }

  .tab-btn:hover {
    border-color: rgba(255, 183, 213, 0.4);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  .tab-btn.active {
    background: linear-gradient(135deg, rgba(255, 107, 157, 0.2), rgba(196, 181, 253, 0.2));
    border-color: var(--sakura-pink);
    color: var(--sakura-pink);
    box-shadow: 0 0 15px rgba(255, 183, 213, 0.2);
  }

  .section-title {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 3rem;
    color: var(--text-primary);
    letter-spacing: 0.1em;
    font-family: 'Ma Shan Zheng', cursive;
  }

  .title-decoration {
    color: var(--sakura-pink);
    font-size: 0.8em;
    margin: 0 0.5rem;
  }

  .timeline {
    position: relative;
    padding: 2rem 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, transparent, var(--lavender) 10%, var(--sakura-pink) 50%, var(--sky-blue) 90%, transparent);
    transform: translateX(-50%);
    box-shadow: 0 0 10px rgba(196, 181, 253, 0.3);
  }

  .timeline-item {
    position: relative;
    width: 45%;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .timeline-item.visible { opacity: 1; transform: translateY(0); }
  .timeline-item.tab-hidden { display: none !important; }
  .timeline-item.left { margin-right: auto; margin-left: 0; padding-right: 3rem; }
  .timeline-item.right { margin-left: auto; margin-right: 0; padding-left: 3rem; }

  .timeline-connector { position: absolute; top: 1.5rem; width: 2px; height: calc(100% - 3rem); }
  .timeline-item.left .timeline-connector { right: -1rem; }
  .timeline-item.right .timeline-connector { left: -1rem; }

  .timeline-dot {
    width: 16px; height: 16px; border-radius: 50%;
    position: absolute; top: 0; transform: translateX(-50%);
    transition: all 0.3s ease; border: 2px solid var(--bg-dark);
  }
  .timeline-item.left .timeline-dot { right: -2rem; }
  .timeline-item.right .timeline-dot { left: -2rem; }

  .color-pink .timeline-dot { background: var(--sakura-pink); box-shadow: 0 0 15px rgba(255, 183, 213, 0.6); }
  .color-blue .timeline-dot { background: var(--sky-blue); box-shadow: 0 0 15px rgba(126, 200, 227, 0.6); }
  .color-purple .timeline-dot { background: var(--lavender); box-shadow: 0 0 15px rgba(196, 181, 253, 0.6); }
  .color-green .timeline-dot { background: var(--mint); box-shadow: 0 0 15px rgba(110, 231, 183, 0.6); }
  .timeline-item:hover .timeline-dot { transform: translateX(-50%) scale(1.4); }

  .timeline-card {
    padding: 1.5rem; border-radius: 16px;
    transition: all 0.3s ease; position: relative; overflow: hidden;
  }
  .timeline-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, transparent, var(--sakura-pink), transparent);
    opacity: 0; transition: opacity 0.3s ease;
  }
  .timeline-card:hover { transform: translateY(-5px); }
  .timeline-card:hover::before { opacity: 1; }
  .color-pink .timeline-card:hover { border-color: rgba(255, 183, 213, 0.3); box-shadow: var(--glow-pink); }
  .color-blue .timeline-card:hover { border-color: rgba(126, 200, 227, 0.3); box-shadow: var(--glow-blue); }
  .color-purple .timeline-card:hover { border-color: rgba(196, 181, 253, 0.3); box-shadow: var(--glow-purple); }
  .color-green .timeline-card:hover { border-color: rgba(110, 231, 183, 0.3); box-shadow: 0 0 20px rgba(110, 231, 183, 0.4); }

  .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; }

  .category-tag {
    font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 12px;
    font-weight: 500; background: rgba(255, 183, 213, 0.1);
    color: var(--sakura-pink); border: 1px solid rgba(255, 183, 213, 0.2);
  }
  .color-blue .category-tag { background: rgba(126, 200, 227, 0.1); color: var(--sky-blue); border-color: rgba(126, 200, 227, 0.2); }
  .color-purple .category-tag { background: rgba(196, 181, 253, 0.1); color: var(--lavender); border-color: rgba(196, 181, 253, 0.2); }
  .color-green .category-tag { background: rgba(110, 231, 183, 0.1); color: var(--mint); border-color: rgba(110, 231, 183, 0.2); }

  .card-date { font-size: 0.8rem; color: var(--text-secondary); }
  .card-title { font-size: 1.2rem; font-weight: 600; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.4rem; }
  .card-icon { font-size: 1.1em; }

  .card-commits {
    margin-top: 1rem; overflow: hidden; max-height: 0; opacity: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease;
  }

  .commit-group {
    margin-bottom: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(255, 183, 213, 0.08);
  }
  .commit-group:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .commit-date {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--sakura-pink);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .color-blue .commit-date { color: var(--sky-blue); }
  .color-purple .commit-date { color: var(--lavender); }
  .color-green .commit-date { color: var(--mint); }

  .commit-list {
    list-style: none;
    padding: 0;
    counter-reset: commit-counter;
  }

  .commit-list li {
    padding: 0.25rem 0 0.25rem 1.8rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.5;
    position: relative;
    counter-increment: commit-counter;
  }

  .commit-list li::before {
    content: counter(commit-counter) ".";
    position: absolute;
    left: 0;
    color: var(--sakura-pink);
    font-weight: 500;
    font-size: 0.78rem;
    min-width: 1.5rem;
  }

  .color-blue .commit-list li::before { color: var(--sky-blue); }
  .color-purple .commit-list li::before { color: var(--lavender); }
  .color-green .commit-list li::before { color: var(--mint); }

  .expand-btn {
    background: none; border: none; color: var(--text-secondary);
    font-size: 0.8rem; cursor: pointer; margin-top: 0.8rem;
    display: flex; align-items: center; gap: 0.3rem;
    transition: color 0.3s ease; font-family: inherit;
  }
  .expand-btn:hover { color: var(--sakura-pink); }
  .expand-icon { font-size: 0.7rem; transition: transform 0.3s ease; }

  @media (max-width: 768px) {
    .timeline::before { left: 1rem; }
    .timeline-item {
      width: calc(100% - 3rem);
      margin-left: 2.5rem !important; margin-right: 0 !important;
      padding-left: 1.5rem; padding-right: 0;
    }
    .timeline-connector { left: -1.5rem !important; right: auto !important; }
    .timeline-dot { left: -2rem !important; right: auto !important; }
    .timeline-section { padding: 2rem 1rem 4rem; }
    .category-tabs { gap: 0.5rem; }
    .tab-btn { padding: 0.4rem 0.8rem; font-size: 0.75rem; }
  }
</style>
