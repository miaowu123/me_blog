<style>
  .deco-stars {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .dstar {
    position: absolute;
    font-size: 1.2rem;
    animation: dtwinkle 2s ease-in-out infinite;
  }
  .ds-1 { top: 10%; left: 5%; color: var(--peach); animation-delay: 0s; font-size: 1rem; }
  .ds-2 { top: 18%; right: 8%; color: var(--sky-blue); animation-delay: 0.3s; font-size: 1.4rem; }
  .ds-3 { top: 30%; left: 12%; color: var(--lavender); animation-delay: 0.6s; font-size: 0.9rem; }
  .ds-4 { top: 42%; right: 15%; color: var(--sakura-pink); animation-delay: 0.9s; font-size: 1.6rem; }
  .ds-5 { top: 55%; left: 8%; color: var(--sakura-deep); animation-delay: 1.2s; font-size: 1.1rem; }
  .ds-6 { top: 65%; right: 5%; color: #6ee7b7; animation-delay: 1.5s; font-size: 1.3rem; }
  .ds-7 { top: 78%; left: 15%; color: var(--peach); animation-delay: 1.8s; font-size: 0.8rem; }
  .ds-8 { top: 88%; right: 12%; color: var(--sky-blue); animation-delay: 0.2s; font-size: 1.5rem; }
  .ds-9 { top: 15%; left: 25%; color: var(--lavender); animation-delay: 0.5s; font-size: 1.2rem; }
  .ds-10 { top: 35%; right: 22%; color: var(--sakura-pink); animation-delay: 0.8s; font-size: 1rem; }
  .ds-11 { top: 48%; left: 20%; color: #c4b5fd; animation-delay: 1.1s; font-size: 1.7rem; }
  .ds-12 { top: 72%; right: 25%; color: var(--sakura-deep); animation-delay: 1.4s; font-size: 0.9rem; }
  .ds-13 { top: 22%; left: 35%; color: var(--peach); animation-delay: 1.7s; font-size: 1.3rem; }
  .ds-14 { top: 58%; right: 30%; color: var(--sky-blue); animation-delay: 0.1s; font-size: 1.1rem; }
  .ds-15 { top: 82%; left: 28%; color: #6ee7b7; animation-delay: 0.4s; font-size: 1.4rem; }
  .ds-16 { top: 12%; right: 35%; color: var(--lavender); animation-delay: 0.7s; font-size: 1rem; }
  .ds-17 { top: 45%; left: 32%; color: var(--sakura-pink); animation-delay: 1s; font-size: 1.6rem; }
  .ds-18 { top: 68%; left: 38%; color: var(--peach); animation-delay: 1.3s; font-size: 0.8rem; }
  .ds-19 { top: 92%; right: 32%; color: var(--sakura-deep); animation-delay: 1.6s; font-size: 1.2rem; }
  .ds-20 { top: 28%; left: 42%; color: var(--sky-blue); animation-delay: 1.9s; font-size: 1.5rem; }

  @keyframes dtwinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }
</style>
