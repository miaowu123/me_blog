<canvas id="particle-canvas"></canvas>

<script>
  const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  let w: number, h: number;

  // === Simplex noise (2D) ===
  function makeNoise2D() {
    const p = new Uint8Array(256);
    for (let i = 0; i < 256; i++) p[i] = (Math.random() * 256) | 0;
    function grad2(hash: number, x: number, y: number) {
      const h = hash & 7;
      const u = h < 4 ? x : y;
      const v = h < 4 ? y : x;
      return (h & 1 ? -u : u) + (h & 2 ? -2 * v : 2 * v);
    }
    const G2 = (3.0 - Math.sqrt(3.0)) / 6.0;
    const F2 = 0.5 * (Math.sqrt(3.0) - 1.0);
    return function noise2D(xin: number, yin: number) {
      let n0 = 0, n1 = 0, n2 = 0;
      const s = (xin + yin) * F2;
      const i = Math.floor(xin + s);
      const j = Math.floor(yin + s);
      const t = (i + j) * G2;
      const X0 = i - t, Y0 = j - t;
      const x0 = xin - X0, y0 = yin - Y0;
      const i1 = x0 > y0 ? 1 : 0;
      const j1 = x0 > y0 ? 0 : 1;
      const x1 = x0 - i1 + G2, y1 = y0 - j1 + G2;
      const x2 = x0 - 1 + 2 * G2, y2 = y0 - 1 + 2 * G2;
      const ii = i & 255, jj = j & 255;
      const t0 = 0.5 - x0 * x0 - y0 * y0;
      if (t0 >= 0) { const gi0 = p[ii + p[jj]]; n0 = t0 * t0 * t0 * t0 * grad2(gi0, x0, y0); }
      const t1 = 0.5 - x1 * x1 - y1 * y1;
      if (t1 >= 0) { const gi1 = p[ii + i1 + p[jj + j1]]; n1 = t1 * t1 * t1 * t1 * grad2(gi1, x1, y1); }
      const t2 = 0.5 - x2 * x2 - y2 * y2;
      if (t2 >= 0) { const gi2 = p[ii + 1 + p[jj + 1]]; n2 = t2 * t2 * t2 * t2 * grad2(gi2, x2, y2); }
      return 40 * (n0 + n1 + n2);
    };
  }
  const noise = makeNoise2D();

  // === Bubbles ===
  interface Bubble {
    x: number; y: number; r: number; color: string;
    vx: number; vy: number; jitter: number; blur: number;
  }
  const bubbles: Bubble[] = [];
  const bubbleColors = ['#ffb7d5', '#7ec8e3', '#c4b5fd', '#ff6b9d', '#6ee7b7', '#fbbf24'];

  // === Stars ===
  const particles: Array<{
    x: number; y: number; vx: number; vy: number;
    r: number; color: string; alpha: number; twinkleSpeed: number;
  }> = [];

  // === Petals ===
  const petals: Array<{
    x: number; y: number; vx: number; vy: number;
    rotation: number; rotationSpeed: number; size: number; alpha: number;
    color: string; wobble: number; wobbleSpeed: number;
  }> = [];
  const petalColors = ['#ffb7d5', '#ffc4dd', '#ff9ec4', '#ffd1e8', '#ffb0c8', '#fff0f5'];

  // === Sparkles ===
  const sparkles: Array<{
    x: number; y: number; vx: number; vy: number;
    size: number; alpha: number; color: string; life: number; maxLife: number;
  }> = [];

  const starColors = ['#ffb7d5', '#7ec8e3', '#c4b5fd', '#fbbf24', '#ff6b9d', '#6ee7b7'];

  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
  }

  function init() {
    resize();

    // Bubbles: 5 large blurred circles
    const bubbleCount = Math.min(20, Math.floor(w / 400));
    for (let i = 0; i < bubbleCount; i++) {
      const r = 200 + Math.random() * 200;
      bubbles.push({
        x: Math.random() * w,
        y: h * 0.7 + Math.random() * h * 0.5,
        r,
        color: bubbleColors[i % bubbleColors.length],
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.2,
        jitter: 0.6 + Math.random() * 0.6,
        blur: 200 + Math.random() * 200,
      });
    }

    // Stars
    const starCount = Math.min(200, Math.floor((w * h) / 6000));
    for (let i = 0; i < starCount; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: Math.random() * 1.5 + 0.4,
        color: starColors[Math.floor(Math.random() * starColors.length)],
        alpha: Math.random() * 0.7 + 0.3,
        twinkleSpeed: Math.random() * 0.03 + 0.01,
      });
    }

    // Petals: 50
    for (let i = 0; i < 60; i++) {
      petals.push({
        x: Math.random() * w,
        y: Math.random() * h * 1.5 - h * 0.5,
        vx: Math.random() * 0.4 + 0.05,
        vy: Math.random() * 0.6 + 0.15,
        rotation: Math.random() * Math.PI * 2,
        rotationSpeed: (Math.random() - 0.5) * 0.02,
        size: Math.random() * 12 + 5,
        alpha: Math.random() * 0.5 + 0.35,
        color: petalColors[Math.floor(Math.random() * petalColors.length)],
        wobble: Math.random() * Math.PI * 2,
        wobbleSpeed: Math.random() * 0.02 + 0.008,
      });
    }

    // Sparkles
    for (let i = 0; i < 40; i++) {
      spawnSparkle();
    }
  }

  function spawnSparkle() {
    sparkles.push({
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * 0.6,
      vy: (Math.random() - 0.5) * 0.6,
      size: Math.random() * 2.5 + 0.8,
      alpha: 0,
      color: starColors[Math.floor(Math.random() * starColors.length)],
      life: 0,
      maxLife: Math.random() * 180 + 80,
    });
  }

  function drawPetal(x: number, y: number, size: number, rotation: number, alpha: number, color: string) {
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(rotation);
    ctx.globalAlpha = alpha;
    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.moveTo(0, 0);
    ctx.bezierCurveTo(size * 0.4, -size * 0.55, size * 0.95, -size * 0.35, size, 0);
    ctx.bezierCurveTo(size * 0.95, size * 0.35, size * 0.4, size * 0.55, 0, 0);
    ctx.fill();
    ctx.fillStyle = 'rgba(255, 255, 255, 0.25)';
    ctx.beginPath();
    ctx.ellipse(size * 0.45, -size * 0.06, size * 0.3, size * 0.12, -0.2, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
  }

  let time = 0;
  let lastTime = 0;

  function updateBubbles(t: number) {
    const noiseScale = 0.0008;
    const noiseTimeScale = 0.00015;
    const speed = 0.12;
    const damping = 0.95;

    for (let i = 0; i < bubbles.length; i++) {
      const b = bubbles[i];
      const n = noise(b.x * noiseScale, b.y * noiseScale + t * noiseTimeScale);
      const angle = n * Math.PI * 2;
      const fx = Math.cos(angle) * speed * b.jitter;
      const fy = Math.sin(angle) * speed * b.jitter;

      // Separation
      let sx = 0, sy = 0;
      for (let j = 0; j < bubbles.length; j++) {
        if (j === i) continue;
        const o = bubbles[j];
        const dx = b.x - o.x, dy = b.y - o.y;
        const d2 = dx * dx + dy * dy;
        const minD = (b.r + o.r) * 0.4;
        if (d2 < minD * minD && d2 > 0.001) {
          const d = Math.sqrt(d2);
          const push = (minD - d) / minD;
          sx += (dx / d) * push * 0.8;
          sy += (dy / d) * push * 0.8;
        }
      }

      b.vx += fx + sx;
      b.vy += fy + sy;
      b.vx *= damping;
      b.vy *= damping;

      const maxVel = 1.5;
      const vel = Math.hypot(b.vx, b.vy);
      if (vel > maxVel) { b.vx = (b.vx / vel) * maxVel; b.vy = (b.vy / vel) * maxVel; }

      b.x += b.vx;
      b.y += b.vy;

      // Wrap
      if (b.x < -b.r - b.blur / 3) b.x = w + b.r + b.blur / 3;
      if (b.x > w + b.r + b.blur / 3) b.x = -b.r - b.blur / 3;
      const bandMin = h * 0.6;
      const bandMax = h * 1.4;
      if (b.y < bandMin) b.vy += 0.02;
      if (b.y > bandMax) b.vy -= 0.02;
    }
  }

  function drawBubbles() {
    for (const b of bubbles) {
      ctx.save();
      ctx.filter = `blur(${b.blur}px)`;
      ctx.globalAlpha = 0.7;
      ctx.beginPath();
      ctx.fillStyle = b.color;
      ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }
  }

  function draw(t: number) {
    ctx.clearRect(0, 0, w, h);
    time += 0.016;

    // Bubbles (low fps - skip frames)
    const dt = t - lastTime;
    if (dt > 160) { // ~6fps
      updateBubbles(t);
      lastTime = t;
    }
    drawBubbles();

    // Stars
    for (const p of particles) {
      p.x += p.vx; p.y += p.vy;
      if (p.x < 0 || p.x > w) p.vx *= -1;
      if (p.y < 0 || p.y > h) p.vy *= -1;
      const twinkle = Math.sin(time * p.twinkleSpeed * 80) * 0.4 + 0.6;
      ctx.globalAlpha = p.alpha * twinkle;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.fill();
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
      const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 3);
      grad.addColorStop(0, p.color);
      grad.addColorStop(1, 'transparent');
      ctx.fillStyle = grad;
      ctx.globalAlpha = p.alpha * twinkle * 0.12;
      ctx.fill();
      ctx.globalAlpha = 1;
    }

    // Petals
    for (const petal of petals) {
      petal.wobble += petal.wobbleSpeed;
      petal.x += petal.vx + Math.sin(petal.wobble) * 0.6;
      petal.y += petal.vy;
      petal.rotation += petal.rotationSpeed + Math.sin(petal.wobble * 0.5) * 0.005;
      if (petal.y > h + 30) { petal.y = -30; petal.x = Math.random() * w; }
      if (petal.x > w + 30) petal.x = -30;
      if (petal.x < -30) petal.x = w + 30;
      drawPetal(petal.x, petal.y, petal.size, petal.rotation, petal.alpha, petal.color);
    }

    // Sparkles
    for (let i = sparkles.length - 1; i >= 0; i--) {
      const s = sparkles[i];
      s.x += s.vx; s.y += s.vy; s.life++;
      const progress = s.life / s.maxLife;
      if (progress < 0.3) s.alpha = progress / 0.3;
      else if (progress > 0.7) s.alpha = (1 - progress) / 0.3;
      else s.alpha = 1;
      ctx.globalAlpha = s.alpha * 0.5;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
      ctx.fillStyle = s.color;
      ctx.fill();
      if (s.life >= s.maxLife) { sparkles.splice(i, 1); spawnSparkle(); }
    }

    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', resize);
  init();
  requestAnimationFrame(draw);
</script>

<style>
  #particle-canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
